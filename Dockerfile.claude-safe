# claude-safe custom template — K8s + DevOps + general development tools
# Base: docker/sandbox-templates:shell (includes Node.js, Python, Go, Git, Docker CLI, grep, sed, awk, curl)
# Adds: K8s toolchain, search tools, build essentials, GitHub CLI, postgres client, network tools
#
# Build:  docker build -t claude-safe -f Dockerfile.claude-safe .
# Works on both arm64 (Apple Silicon / OrbStack) and amd64

FROM docker/sandbox-templates:shell
USER root

# Detect architecture once — reuse in all RUN steps
# TARGETARCH is set by BuildKit (arm64 or amd64)
ARG TARGETARCH

# ── Tool versions — managed by Renovate, do not edit manually ──
# renovate: datasource=github-releases depName=kubernetes/kubernetes
ARG KUBECTL_VERSION=v1.36.0
# renovate: datasource=github-releases depName=helm/helm
ARG HELM_VERSION=v4.1.4
# renovate: datasource=github-releases depName=derailed/k9s
ARG K9S_VERSION=v0.50.18
# renovate: datasource=github-releases depName=stern/stern
ARG STERN_VERSION=v1.33.1
# renovate: datasource=github-releases depName=mikefarah/yq
ARG YQ_VERSION=v4.53.2
# renovate: datasource=github-releases depName=cli/cli
ARG GH_VERSION=v2.91.0
# renovate: datasource=github-releases depName=dandavison/delta
ARG DELTA_VERSION=0.19.2
# renovate: datasource=github-releases depName=sharkdp/bat
ARG BAT_VERSION=v0.26.1
# renovate: datasource=github-releases depName=vi/websocat
ARG WEBSOCAT_VERSION=v1.14.1
# renovate: datasource=github-releases depName=ducaale/xh
ARG XH_VERSION=v0.25.3
# renovate: datasource=github-releases depName=FiloSottile/age
ARG AGE_VERSION=v1.3.1
# renovate: datasource=github-releases depName=getsops/sops
ARG SOPS_VERSION=v3.12.2
# renovate: datasource=github-releases depName=fullstorydev/grpcurl
ARG GRPCURL_VERSION=v1.9.3
# renovate: datasource=github-releases depName=ahmetb/kubectx
ARG KUBECTX_VERSION=v0.11.0
# renovate: datasource=github-releases depName=schollz/croc
ARG CROC_VERSION=v10.4.2
# renovate: datasource=github-releases depName=FiloSottile/mkcert
ARG MKCERT_VERSION=v1.4.4
# renovate: datasource=github-releases depName=go-task/task
ARG TASK_VERSION=v3.50.0
# renovate: datasource=github-releases depName=casey/just
ARG JUST_VERSION=1.50.0
# renovate: datasource=github-releases depName=projectdiscovery/httpx
ARG HTTPX_VERSION=v1.9.0
# renovate: datasource=github-releases depName=jesseduffield/lazygit
ARG LAZYGIT_VERSION=v0.61.1
# renovate: datasource=github-releases depName=kubernetes-sigs/kustomize versioning=regex:^kustomize/v(?<major>\d+)\.(?<minor>\d+)\.(?<patch>\d+)$
ARG KUSTOMIZE_VERSION=5.8.1

# Use bash for all RUN steps (needed for pids+=() array syntax in parallel block)
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# ── System packages ──
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends \
    build-essential \
    jq \
    ripgrep \
    fd-find \
    shellcheck \
    postgresql-client \
    tmux \
    ncurses-term \
    locales \
    unzip \
    zip \
    less \
    wget \
    socat \
    netcat-openbsd \
    fzf \
    tree \
    procps \
    dnsutils \
    iputils-ping \
    strace \
    sqlite3 \
    vim \
    zsh \
    nmap \
    tcpdump \
    direnv \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/fdfind /usr/local/bin/fd \
    && sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen && locale-gen

ENV LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8

# ── All binary tools — downloaded in parallel ──
# Each tool runs in a background subshell; pids are tracked for error propagation.
# Arch aliases: ARCH_MUSL = aarch64/x86_64, ARCH_X = arm64/x86_64 (for tools using x86_64 on amd64)
RUN set -e; \
    ARCH_MUSL=$([ "$TARGETARCH" = "arm64" ] && echo "aarch64" || echo "x86_64"); \
    ARCH_X=$([ "$TARGETARCH" = "amd64" ] && echo "x86_64" || echo "$TARGETARCH"); \
    pids=(); \
    \
    # kubectl
    { curl -fsSL "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/${TARGETARCH}/kubectl" \
         -o /usr/local/bin/kubectl && chmod +x /usr/local/bin/kubectl \
    ; } & pids+=($!); \
    \
    # helm (uses official install script)
    { curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | DESIRED_VERSION=${HELM_VERSION} bash \
    ; } & pids+=($!); \
    \
    # k9s
    { curl -fsSL "https://github.com/derailed/k9s/releases/download/${K9S_VERSION}/k9s_Linux_${TARGETARCH}.tar.gz" \
         | tar xz -C /usr/local/bin k9s \
    ; } & pids+=($!); \
    \
    # stern (multi-pod log tailing)
    { curl -fsSL "https://github.com/stern/stern/releases/download/${STERN_VERSION}/stern_${STERN_VERSION#v}_linux_${TARGETARCH}.tar.gz" \
         | tar xz -C /usr/local/bin stern \
    ; } & pids+=($!); \
    \
    # yq (YAML processor)
    { curl -fsSL "https://github.com/mikefarah/yq/releases/download/${YQ_VERSION}/yq_linux_${TARGETARCH}" \
         -o /usr/local/bin/yq && chmod +x /usr/local/bin/yq \
    ; } & pids+=($!); \
    \
    # GitHub CLI — binary release avoids a second apt-get invocation
    { TMP=$(mktemp -d) \
      && curl -fsSL "https://github.com/cli/cli/releases/download/${GH_VERSION}/gh_${GH_VERSION#v}_linux_${TARGETARCH}.tar.gz" \
         | tar xz -C "$TMP" \
      && mv "$TMP"/gh_*/bin/gh /usr/local/bin/gh && chmod +x /usr/local/bin/gh \
      && rm -rf "$TMP" \
    ; } & pids+=($!); \
    \
    # delta (better git diffs) — tarball avoids dpkg serialization
    { curl -fsSL "https://github.com/dandavison/delta/releases/download/${DELTA_VERSION}/delta-${DELTA_VERSION#v}-${ARCH_MUSL}-unknown-linux-gnu.tar.gz" \
         | tar xz --strip-components=1 -C /usr/local/bin --wildcards "*/delta" \
    ; } & pids+=($!); \
    \
    # bat (better cat, syntax highlighting) — tarball avoids dpkg serialization
    { curl -fsSL "https://github.com/sharkdp/bat/releases/download/${BAT_VERSION}/bat-${BAT_VERSION}-${ARCH_MUSL}-unknown-linux-gnu.tar.gz" \
         | tar xz --strip-components=1 -C /usr/local/bin --wildcards "*/bat" \
    ; } & pids+=($!); \
    \
    # websocat (WebSocket client)
    { curl -fsSL "https://github.com/vi/websocat/releases/download/${WEBSOCAT_VERSION}/websocat.${ARCH_MUSL}-unknown-linux-musl" \
         -o /usr/local/bin/websocat && chmod +x /usr/local/bin/websocat \
    ; } & pids+=($!); \
    \
    # xh (modern HTTP client)
    { curl -fsSL "https://github.com/ducaale/xh/releases/download/${XH_VERSION}/xh-${XH_VERSION}-${ARCH_MUSL}-unknown-linux-musl.tar.gz" \
         | tar xz --strip-components=1 -C /usr/local/bin --wildcards "*/xh" \
    ; } & pids+=($!); \
    \
    # age (file encryption)
    { curl -fsSL "https://github.com/FiloSottile/age/releases/download/${AGE_VERSION}/age-${AGE_VERSION}-linux-${TARGETARCH}.tar.gz" \
         | tar xz --strip-components=1 -C /usr/local/bin age/age age/age-keygen \
    ; } & pids+=($!); \
    \
    # sops (secret decryption)
    { curl -fsSL "https://github.com/getsops/sops/releases/download/${SOPS_VERSION}/sops-${SOPS_VERSION}.linux.${TARGETARCH}" \
         -o /usr/local/bin/sops && chmod +x /usr/local/bin/sops \
    ; } & pids+=($!); \
    \
    # grpcurl
    { curl -fsSL "https://github.com/fullstorydev/grpcurl/releases/download/${GRPCURL_VERSION}/grpcurl_${GRPCURL_VERSION#v}_linux_${ARCH_X}.tar.gz" \
         | tar xz -C /usr/local/bin grpcurl \
    ; } & pids+=($!); \
    \
    # wscat (interactive WebSocket client)
    { npm install -g wscat@6.1.0 \
    ; } & pids+=($!); \
    \
    # kubectx + kubens
    { curl -fsSL "https://github.com/ahmetb/kubectx/releases/download/${KUBECTX_VERSION}/kubectx_${KUBECTX_VERSION}_linux_${ARCH_X}.tar.gz" \
         | tar xz -C /usr/local/bin kubectx \
      && curl -fsSL "https://github.com/ahmetb/kubectx/releases/download/${KUBECTX_VERSION}/kubens_${KUBECTX_VERSION}_linux_${ARCH_X}.tar.gz" \
         | tar xz -C /usr/local/bin kubens \
    ; } & pids+=($!); \
    \
    # kustomize
    { curl -fsSL "https://raw.githubusercontent.com/kubernetes-sigs/kustomize/kustomize/v${KUSTOMIZE_VERSION}/hack/install_kustomize.sh" \
         | bash /dev/stdin "${KUSTOMIZE_VERSION}" /usr/local/bin \
    ; } & pids+=($!); \
    \
    # croc (file transfer)
    { ARCH_CROC=$([ "$TARGETARCH" = "arm64" ] && echo "ARM64" || echo "64bit") \
      && curl -fsSL "https://github.com/schollz/croc/releases/download/${CROC_VERSION}/croc_${CROC_VERSION}_Linux-${ARCH_CROC}.tar.gz" \
         | tar xz -C /usr/local/bin croc \
    ; } & pids+=($!); \
    \
    # mkcert (local TLS certs)
    { curl -fsSL "https://github.com/FiloSottile/mkcert/releases/download/${MKCERT_VERSION}/mkcert-${MKCERT_VERSION}-linux-${TARGETARCH}" \
         -o /usr/local/bin/mkcert && chmod +x /usr/local/bin/mkcert \
    ; } & pids+=($!); \
    \
    # task (Taskfile runner)
    { curl -fsSL "https://github.com/go-task/task/releases/download/${TASK_VERSION}/task_linux_${TARGETARCH}.tar.gz" \
         | tar xz -C /usr/local/bin task \
    ; } & pids+=($!); \
    \
    # just (command runner)
    { curl -fsSL "https://github.com/casey/just/releases/download/${JUST_VERSION}/just-${JUST_VERSION}-${ARCH_MUSL}-unknown-linux-musl.tar.gz" \
         | tar xz -C /usr/local/bin just \
    ; } & pids+=($!); \
    \
    # httpx (HTTP prober)
    { curl -fsSL "https://github.com/projectdiscovery/httpx/releases/download/${HTTPX_VERSION}/httpx_${HTTPX_VERSION#v}_linux_${TARGETARCH}.zip" \
         -o /tmp/httpx.zip \
      && unzip -q /tmp/httpx.zip httpx -d /usr/local/bin \
      && chmod +x /usr/local/bin/httpx && rm /tmp/httpx.zip \
    ; } & pids+=($!); \
    \
    # lazygit
    { curl -fsSL "https://github.com/jesseduffield/lazygit/releases/download/${LAZYGIT_VERSION}/lazygit_${LAZYGIT_VERSION#v}_Linux_${ARCH_X}.tar.gz" \
         | tar xz -C /usr/local/bin lazygit \
    ; } & pids+=($!); \
    \
    # Wait for all downloads; propagate any failures
    exit_code=0; for pid in "${pids[@]}"; do wait "$pid" || exit_code=$?; done; exit "$exit_code"

# ── grml zsh config + ~/.zshrc.d/ support ──
# hadolint ignore=SC2016
RUN curl -fsSL https://git.grml.org/f/grml-etc-core/etc/zsh/zshrc -o /etc/zsh/zshrc \
    && printf '\n# Source ~/.zshrc.d/ drop-ins\nif [[ -d "${ZDOTDIR:-$HOME}/.zshrc.d" ]]; then\n  for _f in "${ZDOTDIR:-$HOME}"/.zshrc.d/*.{sh,zsh}(N); do\n    source "$_f"\n  done\nfi\n' \
       >> /etc/zsh/zshrc \
    && chsh -s /bin/zsh agent \
    && touch /home/agent/.zshrc && chown agent:agent /home/agent/.zshrc \
    && printf '\n# direnv\neval "$(direnv hook zsh)"\n' \
       >> /etc/zsh/zshrc

# ── direnv config (auto-allow by default; override with DIRENV_CONFIG=/etc/direnv-strict) ──
RUN mkdir -p /etc/direnv /etc/direnv-strict \
    && printf '[whitelist]\nprefix = ["/"]\n' > /etc/direnv/direnv.toml
ENV DIRENV_CONFIG=/etc/direnv

# ── grml vim config ──
RUN curl -fsSL https://git.grml.org/f/grml-etc-core/etc/vim/vimrc -o /etc/vim/vimrc.local

# ── Install Claude Code ──
ARG CLAUDE_CODE_CACHEBUST=0
RUN npm install -g @anthropic-ai/claude-code@latest

USER agent
