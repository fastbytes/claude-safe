cmd_custom() {
    local subcmd="${1:-}"
    local project_root; project_root="$(_repo_root 2>/dev/null)" || {
        _error "Not in a git repository"; return 1; }
    local override_file="${project_root}/.claude-safe/config"

    case "$subcmd" in
        --list|-l)
            if [[ ! -f "$_TRUSTED_FILE" ]]; then
                _info "No trusted project overrides."
            else
                echo -e "\n${BOLD}Trusted project overrides:${NC}"
                while IFS= read -r p; do
                    [[ -z "$p" ]] && continue
                    if [[ -f "$p" ]]; then
                        echo -e "  ${GREEN}✓${NC} $p"
                    else
                        echo -e "  ${DIM}✗ $p (file not found)${NC}"
                    fi
                done < "$_TRUSTED_FILE"
                echo ""
            fi
            ;;
        --path|-p)
            echo "$override_file"
            ;;
        --rm)
            if [[ -f "$override_file" ]]; then
                rm -f "$override_file"
                _info "Removed: $override_file"
                rmdir "$(dirname "$override_file")" 2>/dev/null || true
            else
                _warn "No override file found: $override_file"
            fi
            _untrust_override "$override_file"
            _info "Untrusted: $override_file"
            ;;
        "")
            mkdir -p "$(dirname "$override_file")"
            if [[ ! -f "$override_file" ]]; then
                _generate_override_template > "$override_file"
                chmod 644 "$override_file"
                _info "Created: $override_file"
            fi
            _trust_override "$override_file"
            _info "Trusted: $override_file"
            local editor="${EDITOR:-vi}"
            "$editor" "$override_file"
            ;;
        *)
            _error "Unknown option: $subcmd"
            echo "Usage: claude-safe custom [--list|--path|--rm]"
            return 1
            ;;
    esac
}

cmd_doctor() {
    echo -e "\n${BOLD}claude-safe doctor${NC}\n"
    local ok=0 w=0 f=0
    _ck()  { local label="${@: -1}"; "$@" &>/dev/null && { echo -e "  ${GREEN}✓${NC} $label"; ok=$((ok+1)); } || { echo -e "  ${RED}✗${NC} $label"; f=$((f+1)); }; }
    _ckw() { local label="${@: -1}"; "$@" &>/dev/null && { echo -e "  ${GREEN}✓${NC} $label"; ok=$((ok+1)); } || { echo -e "  ${YELLOW}?${NC} $label ${DIM}(optional)${NC}"; w=$((w+1)); }; }

    _ck command -v git; _ck command -v docker
    _ckw command -v claude; _ckw command -v mosh-server
    _ckw command -v jq
    _ckw command -v kubectl; _ckw command -v helm; _ckw command -v k9s
    echo ""
    [[ -n "${_GLOBAL_CONFIG_FILE:-}" ]]  && echo -e "  ${GREEN}✓${NC} Config: ${_GLOBAL_CONFIG_FILE}" || echo -e "  ${YELLOW}?${NC} No config"
    [[ -d "$CLAUDE_HOME" ]]             && echo -e "  ${GREEN}✓${NC} ~/.claude/"                   || echo -e "  ${RED}✗${NC} ~/.claude/"
    [[ -d "$HOME/.kube" ]]              && echo -e "  ${GREEN}✓${NC} ~/.kube/"                     || echo -e "  ${YELLOW}?${NC} ~/.kube/"
    [[ -d "$HOME/.ssh" ]]               && echo -e "  ${GREEN}✓${NC} ~/.ssh/"                      || echo -e "  ${YELLOW}?${NC} ~/.ssh/"
    if [[ "$CLAUDE_SAFE_MOUNT_SSH" == "true" ]] && [[ "${CLAUDE_SAFE_SSH_MODE:-agent}" == "agent" ]]; then
        [[ -n "${SSH_AUTH_SOCK:-}" ]] && [[ -S "${SSH_AUTH_SOCK:-}" ]] \
            && echo -e "  ${GREEN}✓${NC} SSH_AUTH_SOCK set (agent mode)" \
            || echo -e "  ${YELLOW}?${NC} SSH_AUTH_SOCK not set — git SSH may fail (set SSH_MODE=keys or start ssh-agent)"
    fi
    if [[ -n "$CLAUDE_SAFE_RO_DIRS" ]]; then
        local _ifs="$IFS"; IFS=':'
        for _dir in $CLAUDE_SAFE_RO_DIRS; do
            IFS="$_ifs"
            [[ -d "$_dir" ]] && echo -e "  ${GREEN}✓${NC} ${_dir} (ro)" || echo -e "  ${YELLOW}?${NC} ${_dir} (ro)"
        done
        IFS="$_ifs"
    fi
    [[ -n "${CLAUDE_SAFE_KUBE_PROFILES:-}" ]] && {
        local _ifs="$IFS"; IFS=':'
        for ctx in $CLAUDE_SAFE_KUBE_PROFILES; do
            IFS="$_ifs"
            KUBECONFIG="$HOME/.kube/config" kubectl config get-contexts "$ctx" &>/dev/null \
                && echo -e "  ${GREEN}✓${NC} kube context: $ctx" \
                || echo -e "  ${RED}✗${NC} kube context not found: $ctx"
        done
        IFS="$_ifs"
    }
    echo ""

    # Docker runtime detection
    local _docker_ctx; _docker_ctx="$(docker context show 2>/dev/null || echo "")"
    if docker version &>/dev/null; then
        local server_info; server_info="$(docker version --format '{{.Server.Platform.Name}}' 2>/dev/null || echo "unknown")"
        if echo "$server_info" | grep -qi orbstack || echo "$_docker_ctx" | grep -qi orbstack; then
            echo -e "  ${GREEN}✓${NC} Docker via OrbStack"
        elif echo "$_docker_ctx" | grep -qi colima; then
            echo -e "  ${GREEN}✓${NC} Docker via Colima"
        elif echo "$server_info" | grep -qi "docker desktop"; then
            echo -e "  ${GREEN}✓${NC} Docker via Docker Desktop"
            docker sandbox version &>/dev/null \
                && echo -e "  ${GREEN}✓${NC} docker sandbox plugin" \
                || echo -e "  ${YELLOW}?${NC} docker sandbox (need Desktop 4.50+)"
        else
            echo -e "  ${GREEN}✓${NC} Docker Engine ($server_info)"
        fi
        # buildx check (optional — _docker_build() falls back to legacy builder)
        if docker buildx version &>/dev/null; then
            echo -e "  ${GREEN}✓${NC} docker buildx"; ok=$((ok+1))
        else
            echo -e "  ${YELLOW}?${NC} docker buildx not found ${DIM}(builds will use legacy builder)${NC}"; w=$((w+1))
            if [[ "$(uname)" == "Darwin" ]]; then
                echo -e "     ${DIM}Install: brew install docker-buildx${NC}"
            else
                echo -e "     ${DIM}Install: https://github.com/docker/buildx#installing${NC}"
            fi
        fi
        # credential helper check (only when credsStore is configured)
        local _creds_store; _creds_store="$(_detect_creds_store || true)"
        if [[ -n "$_creds_store" ]]; then
            if command -v "docker-credential-${_creds_store}" &>/dev/null; then
                echo -e "  ${GREEN}✓${NC} docker-credential-${_creds_store}"; ok=$((ok+1))
            else
                echo -e "  ${RED}✗${NC} docker-credential-${_creds_store} not found (required by ~/.docker/config.json)"; f=$((f+1))
                [[ "$(uname)" == "Darwin" && "$_creds_store" == "osxkeychain" ]] \
                    && echo -e "     ${DIM}Install: brew install docker-credential-helper${NC}"
            fi
        fi
    else
        echo -e "  ${RED}✗${NC} Docker not responding"
    fi

    # Resolved image check
    local _resolved_image; _resolved_image="$(_resolve_image)"
    if docker image inspect "$_resolved_image" &>/dev/null; then
        echo -e "  ${GREEN}✓${NC} Image: $_resolved_image"
        docker run --rm "$_resolved_image" tmux -V &>/dev/null \
            && echo -e "  ${GREEN}✓${NC} tmux in image" \
            || echo -e "  ${RED}✗${NC} tmux not found in image (required for session management)"
    else
        if _is_custom_template; then
            echo -e "  ${RED}✗${NC} Image missing: $_resolved_image (run: claude-safe update --build)"
        else
            echo -e "  ${YELLOW}?${NC} Image not cached: $_resolved_image (will pull on next launch)"
        fi
    fi
    # Detect orphaned legacy local image
    if ! _is_custom_template && docker image inspect "claude-safe" &>/dev/null 2>&1; then
        echo -e "  ${YELLOW}?${NC} Orphaned local image 'claude-safe' found ${DIM}(pre-GHCR era — safe to remove: docker rmi claude-safe)${NC}"
    fi

    # Image freshness
    local _stamp="${CONFIG_DIR}/.last-update"
    [[ -f "${CONFIG_DIR}/.last-build" ]] && [[ ! -f "$_stamp" ]] && _stamp="${CONFIG_DIR}/.last-build"
    if [[ "$CLAUDE_SAFE_BUILD_INTERVAL" == "-1" ]]; then
        echo -e "  ${YELLOW}?${NC} Auto-update disabled (BUILD_INTERVAL=-1)"
    elif [[ -f "$_stamp" ]]; then
        local _last _age _ago; _last="$(<"$_stamp")"; _age=$(( $(date +%s) - _last ))
        if (( _age < 3600 )); then _ago="$(( _age / 60 ))m ago"
        elif (( _age < 86400 )); then _ago="$(( _age / 3600 ))h ago"
        else _ago="$(( _age / 86400 ))d ago"; fi
        echo -e "  ${GREEN}✓${NC} Last image update: ${_ago}"
    else
        echo -e "  ${YELLOW}?${NC} Image never pulled/built — will update on next launch"
    fi

    # GitHub CLI config
    [[ "$CLAUDE_SAFE_MOUNT_GH" == "true" ]] && {
        [[ -d "$HOME/.config/gh" ]] \
            && echo -e "  ${GREEN}✓${NC} ~/.config/gh/ (gh CLI auth)" \
            || echo -e "  ${YELLOW}?${NC} ~/.config/gh/ missing — run 'gh auth login' on host"
    }

    # Claude OAuth credentials (macOS Keychain)
    if [[ "$(uname)" == "Darwin" ]]; then
        security find-generic-password -s "Claude Code-credentials" -w &>/dev/null \
            && echo -e "  ${GREEN}✓${NC} Claude OAuth in macOS Keychain" \
            || echo -e "  ${RED}✗${NC} No Claude OAuth in Keychain — run 'claude' on host to login"
    elif [[ -f "${CLAUDE_HOME}/.credentials.json" ]] && [[ -s "${CLAUDE_HOME}/.credentials.json" ]]; then
        echo -e "  ${GREEN}✓${NC} ~/.claude/.credentials.json"
    else
        echo -e "  ${YELLOW}?${NC} No credentials file — need 'claude login' or ANTHROPIC_API_KEY"
    fi

    # Host env var forwarding
    [[ -n "${CLAUDE_SAFE_HOST_ENV:-}" ]] && {
        echo ""
        for varname in $CLAUDE_SAFE_HOST_ENV; do
            local _val="${!varname:-}"
            [[ -n "$_val" ]] \
                && echo -e "  ${GREEN}✓${NC} \$${varname} set (${#_val} chars)" \
                || echo -e "  ${YELLOW}?${NC} \$${varname} not set on host"
        done
    }

    # Quick host-network check
    if [[ "$CLAUDE_SAFE_NETWORK" == "host" ]]; then
        docker run --rm --network host alpine:3.20 sh -c "echo ok" &>/dev/null \
            && echo -e "  ${GREEN}✓${NC} --network host works" \
            || echo -e "  ${YELLOW}?${NC} --network host may not work (check your Docker runtime settings)"
    fi

    # Docker socket mode checks
    case "$CLAUDE_SAFE_DOCKER_SOCKET" in
        proxy)
            echo ""
            [[ -S /var/run/docker.sock ]] \
                && { echo -e "  ${GREEN}✓${NC} /var/run/docker.sock exists (proxy mode)"; ok=$((ok+1)); } \
                || { echo -e "  ${RED}✗${NC} /var/run/docker.sock not found (required for proxy mode)"; f=$((f+1)); }
            docker pull tecnativa/docker-socket-proxy:latest &>/dev/null \
                && { echo -e "  ${GREEN}✓${NC} tecnativa/docker-socket-proxy image available"; ok=$((ok+1)); } \
                || { echo -e "  ${YELLOW}?${NC} tecnativa/docker-socket-proxy not cached — will pull on first launch"; w=$((w+1)); }
            local _orphans; _orphans="$(docker ps -a --filter name=cs-socket-proxy- --format '{{.Names}}' 2>/dev/null)"
            [[ -n "$_orphans" ]] && echo -e "  ${YELLOW}?${NC} Orphaned proxy containers: ${_orphans} ${DIM}(run: claude-safe stop)${NC}"
            ;;
        true)
            echo ""
            if [[ "$CLAUDE_SAFE_DOCKER_SOCKET_CONFIRM" == "true" ]]; then
                echo -e "  ${YELLOW}!${NC} Docker socket=true — container has full host root access"; w=$((w+1))
            else
                echo -e "  ${RED}✗${NC} DOCKER_SOCKET=true requires DOCKER_SOCKET_CONFIRM=true"; f=$((f+1))
            fi
            ;;
    esac

    # Asset directory check
    local _asset_dir; _asset_dir="$(_asset_dir)"
    local _repo_dir="${CONFIG_DIR}/repo"
    if [[ "$_asset_dir" != "$_repo_dir" ]]; then
        echo -e "  ${GREEN}✓${NC} Assets: ${_asset_dir} ${DIM}(local checkout)${NC}"; ok=$((ok+1))
    elif [[ -d "${_repo_dir}/.git" ]]; then
        local _asset_ver; _asset_ver="$(git -C "$_repo_dir" describe --tags --exact-match 2>/dev/null || git -C "$_repo_dir" rev-parse --short HEAD 2>/dev/null || echo "unknown")"
        echo -e "  ${GREEN}✓${NC} Assets: ${_repo_dir} ${DIM}(${_asset_ver})${NC}"; ok=$((ok+1))
    else
        echo -e "  ${YELLOW}?${NC} Assets not cloned — will clone on next update or first use"; w=$((w+1))
    fi

    # Project override check
    local project_root; project_root="$(_repo_root 2>/dev/null || echo "")"
    if [[ -n "$project_root" ]]; then
        local override="${project_root}/.claude-safe/config"
        if [[ -f "$override" ]]; then
            if _is_trusted "$override"; then
                echo -e "  ${GREEN}✓${NC} Project override: ${override} ${DIM}(trusted)${NC}"; ok=$((ok+1))
            else
                echo -e "  ${YELLOW}?${NC} Project override found but not trusted: ${override}"; w=$((w+1))
                echo -e "     ${DIM}Run: claude-safe custom  to trust and load it${NC}"
            fi
        else
            local project_name; project_name="$(basename "$project_root")"
            echo -e "  ${DIM}  No project override for ${project_name}${NC}"
        fi
    fi

    echo -e "\n  ${ok} ok, ${w} warn, ${f} fail\n"
    [[ $f -eq 0 ]]
}

# ─── Completions ─────────────────────────────────────────────────────────────

# Single definition — used both when sourced and emitted by --completions.
_CS_COMP_BODY='_cs_comp() {
    local cmds="new start ls rm merge shell stop dash install update config custom doctor tmux direct"
    local cur="${COMP_WORDS[COMP_CWORD]}" cmd="${COMP_WORDS[1]:-}"
    case "$cmd" in
        start|rm|merge|shell|stop)
            local r d b=""; r="$(git rev-parse --show-toplevel 2>/dev/null)" || return
            d="${r}/.worktrees"; [[ -d "$d" ]] && b="$(ls "$d" 2>/dev/null)"
            COMPREPLY=($(compgen -W "$b" -- "$cur")) ;;
        update)
            COMPREPLY=($(compgen -W "--build --skip-script --skip-assets" -- "$cur")) ;;
        *) COMPREPLY=($(compgen -W "$cmds" -- "$cur")) ;;
    esac
}'

if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    eval "$_CS_COMP_BODY"
    complete -F _cs_comp claude-safe; return 0
fi

# ─── Main ────────────────────────────────────────────────────────────────────

_load_config

# Cleanup credentials and staging on any exit (normal, Ctrl-C, SIGTERM, set -e).
# Without this, OAuth tokens and COW staging copies persist after abnormal exits.
_cleanup_on_exit() {
    rm -f "${CLAUDE_HOME}/.credentials.json" 2>/dev/null || true
    if [[ -n "${_COW_STAGING_DIR:-}" ]]; then
        rm -rf "$_COW_STAGING_DIR" 2>/dev/null || true
    else
        rm -rf "${CONFIG_DIR}/.cow-staging" 2>/dev/null || true
    fi
}
trap _cleanup_on_exit EXIT

if [[ "${1:-}" == "--dangerous" ]]; then
    CLAUDE_SAFE_PERMISSION_MODE="bypass"
    shift
fi

case "${1:-}" in
    new)     shift; cmd_new "$@" ;;
    start)   shift; cmd_start "$@" ;;
    ls)      cmd_ls ;;
    rm)      shift; cmd_rm "$@" ;;
    merge)   shift; cmd_merge "$@" ;;
    shell)   shift; cmd_shell "${1:-}" ;;
    stop)    shift; cmd_stop "$@" ;;
    dash)    cmd_dash ;;
    install) cmd_install ;;
    update)  shift; cmd_update "$@" ;;
    config)  shift; cmd_config "${1:-}" ;;
    custom)  shift; cmd_custom "$@" ;;
    doctor)  cmd_doctor ;;
    tmux)    shift; cmd_tmux "$@" ;;
    direct)  shift; cmd_direct "$@" ;;
    version|-V) echo "claude-safe v${CLAUDE_SAFE_VERSION}" ;;
    --completions) printf '%s\n' "$_CS_COMP_BODY" "complete -F _cs_comp claude-safe" ;;
    -h|--help|help) cat << EOF
${BOLD}claude-safe v${CLAUDE_SAFE_VERSION}${NC} — Sandboxed Claude Code with worktrees

${BOLD}USAGE${NC}
  claude-safe [command] [options]

${BOLD}SESSIONS${NC}
  (default)               Smart reattach or create session
  new <branch> [prompt]   Create worktree + sandbox + session
  start <branch>          Reattach to existing session
  stop <branch>           Stop container
  rm <branch>             Stop container + remove worktree

${BOLD}TOOLS${NC}
  ls                      List containers and sessions
  dash                    Container overview dashboard
  merge <branch> [--squash]  Merge worktree branch back
  shell [branch]          Shell into container

${BOLD}LAUNCH MODES${NC}
  tmux [args]             Force tmux session
  direct [args]           Direct launch (no tmux)
  --dangerous             Bypass Claude permission prompts

${BOLD}SETUP${NC}
  install                 Interactive installer / reconfigure
  update [--build]        Pull image from GHCR + self-update script
  config                  Show current configuration
  config --reconfigure    Interactive wizard to update all settings
  config --migrate        Migrate legacy config.sh
  custom [--list|--rm]    Manage per-project config overrides
  doctor                  Verify setup
  version                 Show version

${DIM}Tip: CLAUDE_SAFE_TMUX=false in config to always launch without tmux${NC}
EOF
        ;;
    "") cmd_auto ;;
    *)  cmd_auto "$@" ;;
esac
