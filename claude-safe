cmd_update() {
    # Update the Docker image (pull from GHCR or build locally) and self-update the script.
    # Usage: update [--build] [--skip-script] [--skip-assets]
    _require docker
    local build_flag=false skip_script=false skip_assets=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --build)        build_flag=true ;;
            --skip-script)  skip_script=true ;;
            --skip-assets)  skip_assets=true ;;
            *) _error "Unknown option: $1"; return 1 ;;
        esac
        shift
    done

    local stamp_file="${CONFIG_DIR}/.last-update"
    # One-time migration: rename old stamp file
    [[ -f "${CONFIG_DIR}/.last-build" ]] && [[ ! -f "$stamp_file" ]] \
        && mv "${CONFIG_DIR}/.last-build" "$stamp_file"
    mkdir -p "${CONFIG_DIR}"

    # Fetch latest release version once; used by asset and image steps below.
    local latest_ver; latest_ver="$(_get_latest_script_version 2>/dev/null)" || true
    local release_ver="${latest_ver:-$CLAUDE_SAFE_VERSION}"

    # Step 1: Script self-update from GitHub Releases
    if [[ "$skip_script" == "false" ]]; then
        _self_update || true
    fi

    # Step 2: Asset repo sync (Dockerfile, config.example, tmux.conf)
    # Pass the release version explicitly so assets use the correct tag even when the
    # embedded CLAUDE_SAFE_VERSION string wasn't bumped in the released script.
    if [[ "$skip_assets" == "false" ]]; then
        _update_assets "$release_ver" || true
    fi

    # Step 3: Image update
    local pull_tag="$release_ver"
    local image
    if [[ -n "$CLAUDE_SAFE_TEMPLATE" ]]; then
        image="$CLAUDE_SAFE_TEMPLATE"
    else
        image="${CLAUDE_SAFE_GHCR_IMAGE}:${pull_tag}"
    fi
    if [[ "$build_flag" == "true" ]] || _is_custom_template; then
        # Local build (forced or custom template)
        local dockerfile; dockerfile="$(_find_dockerfile)"
        [[ -f "$dockerfile" ]] || { _error "Dockerfile.claude-safe not found"; return 1; }
        local build_args=(-f "$dockerfile" -t "$image" --build-arg "CLAUDE_CODE_CACHEBUST=$(date +%s)" "$(dirname "$dockerfile")")
        _info "Building image: ${CYAN}${image}${NC}"
        _pull_base_image "$dockerfile"
        if _docker_build "${build_args[@]}"; then
            date +%s > "$stamp_file"
            _info "Image built: ${CYAN}${image}${NC}"
        else
            _error "Image build failed"
            return 1
        fi
    else
        # Pull from GHCR
        _info "Pulling image: ${CYAN}${image}${NC}"
        if docker pull "$image"; then
            date +%s > "$stamp_file"
            _info "Image updated: ${CYAN}${image}${NC}"
        else
            _error "Image pull failed"
            return 1
        fi
    fi

    _update_config
}

_cfg_src() {
    # Print colored source label for a config variable: (override), (global), or (default).
    local var="$1"
    if [[ -n "${_OVERRIDE_FILE:-}" ]] && grep -q "^[[:space:]]*${var}=" "$_OVERRIDE_FILE" 2>/dev/null; then
        printf '%b(override)%b' "$YELLOW" "$NC"
    elif [[ -n "${_GLOBAL_CONFIG_FILE:-}" ]] && grep -q "^[[:space:]]*${var}=" "$_GLOBAL_CONFIG_FILE" 2>/dev/null; then
        printf '%b(global)%b' "$DIM" "$NC"
    else
        printf '%b(default)%b' "$DIM" "$NC"
    fi
}

_convert_config_sh() {
    # Convert legacy config.sh (bash) to new declarative config format.
    local old="${CONFIG_DIR}/config.sh" new="${CONFIG_DIR}/config"
    if [[ ! -f "$old" ]]; then
        _info "No config.sh to migrate."; return 0; fi
    if [[ -f "$new" ]]; then
        _warn "Both config.sh and config exist. Edit $new directly."; return 1; fi
    {
        echo "# Migrated from config.sh on $(date +%Y-%m-%d)"
        echo "# Review and delete config.sh when satisfied."
        echo ""
        grep -E '^[[:space:]]*CLAUDE_SAFE_[A-Z_]+=' "$old" | sed 's/^[[:space:]]*//'
    } > "$new"
    chmod 600 "$new"
    _info "Created: $new"
    _info "Review it, then delete config.sh"
}

